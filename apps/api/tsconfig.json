{
    "compilerOptions": {
        "baseUrl": "./src/",
        "paths": {
            "@sealed-vote/contracts": ["../../../packages/contracts/src/index.ts"],
            "@sealed-vote/protocol": ["../../../packages/protocol/src/index.ts"],
            "@sealed-vote/testkit": ["../../../packages/testkit/src/index.ts"]
        },
        "target": "esnext",
        "module": "esnext",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "ignoreDeprecations": "6.0",
        "allowArbitraryExtensions": true,
        "removeComments": true,
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "ts-node": {
        "require": ["tsconfig-paths/register"]
    },
    "include": ["src/**/*", "scripts/**/*", "vitest.config.ts", "drizzle.config.ts"]
}
