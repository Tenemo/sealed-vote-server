{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {},
        "outDir": "./dist/",
        "rootDir": "./src",
        "target": "ES2020",
        "module": "esnext",
        "moduleResolution": "bundler",
        "ignoreDeprecations": "6.0",
        "noEmit": false,
        "declaration": true,
        "sourceMap": false,
        "removeComments": false,
        "esModuleInterop": false
    },
    "include": ["src/**/*"],
    "exclude": [
        "node_modules",
        "**/*.spec.ts",
        "src/test/**/*",
        "**/setup.ts",
        "eslint.config.js",
        "vitest.config.js"
    ]
}
