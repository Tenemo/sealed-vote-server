{
    "name": "@sealed-vote/api",
    "version": "2.3.0",
    "description": "sealed-vote-api",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "AGPL-3.0-only",
    "scripts": {
        "start": "node dist/server.js",
        "build": "tsc --project tsconfig.build.json",
        "clean": "del-cli dist",
        "start:dev": "cross-env NODE_ENV=development tsx src/server.ts",
        "dev": "cross-env NODE_ENV=development nodemon",
        "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
        "db:migrate": "tsx scripts/database.ts migrate",
        "db:reset": "tsx scripts/database.ts reset",
        "db:seed": "tsx scripts/database.ts seed",
        "db:setup": "pnpm db:reset && pnpm db:seed",
        "lint": "pnpm --workspace-root exec eslint apps/api",
        "lint:fix": "pnpm --workspace-root exec eslint apps/api --fix",
        "typecheck": "tsc",
        "test": "cross-env NODE_ENV=test vitest run --reporter verbose",
        "test:watch": "vitest watch --clearScreen"
    },
    "type": "module",
    "engines": {
        "node": ">=24.14.1"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@sealed-vote/contracts": "workspace:*",
        "@sealed-vote/protocol": "workspace:*",
        "@sinclair/typebox": "catalog:",
        "@sindresorhus/slugify": "^3.0.0",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.8.5",
        "http-errors": "^2.0.1",
        "pg": "^8.20.0",
        "pino-pretty": "^13.1.3",
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "@sealed-vote/testkit": "workspace:*",
        "@types/http-errors": "^2.0.5",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-v8": "catalog:",
        "del-cli": "^7.0.0",
        "drizzle-kit": "^0.31.10",
        "nodemon": "^3.1.14",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
