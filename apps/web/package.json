{
    "name": "@sealed-vote/web",
    "version": "2.0.0",
    "private": true,
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "description": "sealed.vote web application",
    "scripts": {
        "start": "cross-env NODE_ENV=development pnpm run open:src",
        "dev": "pnpm start",
        "build": "cross-env NODE_ENV=production webpack --config config/webpack/webpack.prod.babel.ts",
        "build:analyze": "pnpm run clean && cross-env NODE_ENV=production ANALYZE=true webpack --config config/webpack/webpack.prod.babel.ts",
        "clean": "rimraf ./dist && mkdir dist",
        "eslint": "eslint . -c eslint.config.js",
        "eslint:fix": "eslint . --fix -c eslint.config.js",
        "stylelint": "stylelint **/*.scss **/*.css",
        "lint": "pnpm run eslint && pnpm run stylelint",
        "open:dist": "http-server dist --port 4000 --proxy http://localhost:4000?",
        "open:src": "cross-env PORT=3000 webpack serve --config config/webpack/webpack.dev.babel.ts",
        "typecheck": "tsc",
        "test": "cross-env NODE_ENV=test jest --passWithNoTests",
        "test:update": "pnpm run test -- --update",
        "test:coverage": "pnpm run test -- --coverage",
        "test:watch": "pnpm run test -- --watch"
    },
    "browserslist": [
        "> 0.5%",
        "not dead",
        "not IE > 0",
        "not op_mini all"
    ],
    "type": "module",
    "overrides": {
        "@pmmmwh/react-refresh-webpack-plugin": {
            "webpack-dev-server": "^5.0.4"
        }
    },
    "dependencies": {
        "@sealed-vote/contracts": "workspace:*",
        "@sealed-vote/protocol": "workspace:*",
        "@babel/runtime-corejs3": "^7.24.4",
        "@emotion/react": "^11.11.4",
        "@emotion/styled": "^11.11.5",
        "@mui/icons-material": "^5.15.15",
        "@mui/material": "^5.15.15",
        "@reduxjs/toolkit": "^2.2.3",
        "@sentry/browser": "^7.109.0",
        "@sentry/react": "^7.109.0",
        "axios": "^1.6.8",
        "copy-to-clipboard": "^3.3.3",
        "core-js": "^3.36.1",
        "history": "^5.3.0",
        "normalize.css": "^8.0.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-error-boundary": "^4.0.13",
        "react-helmet-async": "^2.0.4",
        "react-redux": "^9.1.0",
        "react-router": "^6.22.3",
        "react-router-dom": "^6.22.3",
        "redux": "^5.0.1",
        "redux-persist": "^6.0.0",
        "redux-thunk": "^3.1.0",
        "reselect": "^5.1.0",
        "threshold-elgamal": "catalog:",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@babel/core": "^7.24.4",
        "@babel/node": "^7.23.9",
        "@babel/plugin-proposal-class-properties": "^7.16.7",
        "@babel/register": "^7.28.3",
        "@babel/preset-env": "^7.24.4",
        "@babel/preset-react": "^7.24.1",
        "@babel/preset-typescript": "^7.24.1",
        "@eslint/eslintrc": "^3.0.2",
        "@eslint/js": "^8.57.0",
        "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
        "@teamsupercell/typings-for-css-modules-loader": "^2.5.2",
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/react": "^14.3.0",
        "@testing-library/user-event": "^14.5.2",
        "@types/circular-dependency-plugin": "^5.0.8",
        "@types/core-js": "^2.5.8",
        "@types/eslint": "^8.56.7",
        "@types/eslint-plugin-prettier": "^3.1.3",
        "@types/history": "^4.7.11",
        "@types/html-webpack-plugin": "^3.2.9",
        "@types/http-server": "^0.12.4",
        "@types/ip": "^1.1.3",
        "@types/jest": "^29.5.12",
        "@types/jsdom": "^21.1.6",
        "@types/mini-css-extract-plugin": "^2.5.0",
        "@types/node": "^20.12.7",
        "@types/npm": "^7.19.3",
        "@types/prettier": "^2.7.3",
        "@types/react": "^18.2.75",
        "@types/react-dom": "^18.2.24",
        "@types/react-redux": "^7.1.33",
        "@types/react-router": "^5.1.20",
        "@types/react-router-dom": "^5.3.3",
        "@types/redux-logger": "^3.0.13",
        "@types/redux-mock-store": "^1.0.6",
        "@types/sass": "^1.43.1",
        "@types/uuid": "^9.0.8",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@types/webpack-env": "^1.18.4",
        "@typescript-eslint/eslint-plugin": "^7.6.0",
        "@typescript-eslint/parser": "^7.6.0",
        "autoprefixer": "^10.4.19",
        "babel-jest": "^29.7.0",
        "babel-loader": "^9.1.3",
        "babel-plugin-module-resolver": "^5.0.0",
        "circular-dependency-plugin": "^5.2.2",
        "copy-webpack-plugin": "^12.0.2",
        "cross-env": "^7.0.3",
        "css-loader": "^6.11.0",
        "css-minimizer-webpack-plugin": "^6.0.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-jest": "27.9",
        "eslint-plugin-jsx-a11y": "^6.8.0",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "4.6.0",
        "eslint-plugin-security": "^2.1.1",
        "globals": "^15.0.0",
        "html-webpack-plugin": "^5.6.0",
        "http-server": "^14.1.1",
        "ip": "^2.0.1",
        "jest": "^29.7.0",
        "jest-cli": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "jsdom": "^24.0.0",
        "mini-css-extract-plugin": "^2.8.1",
        "postcss": "^8.4.38",
        "postcss-flexbugs-fixes": "^5.0.2",
        "postcss-html": "^1.6.0",
        "postcss-loader": "^8.1.1",
        "prettier": "^3.2.5",
        "prettier-eslint": "^16.3.0",
        "prettier-stylelint": "^0.4.2",
        "react-refresh": "^0.14.0",
        "redux-logger": "^3.0.6",
        "redux-mock-store": "^1.5.4",
        "rimraf": "catalog:",
        "sass": "^1.74.1",
        "sass-loader": "^14.1.1",
        "style-loader": "^3.3.4",
        "stylelint": "^16.3.1",
        "stylelint-config-recommended": "^14.0.0",
        "stylelint-config-recommended-scss": "^14.0.0",
        "stylelint-scss": "^6.2.1",
        "typescript": "catalog:",
        "webpack": "^5.91.0",
        "webpack-bundle-analyzer": "^4.10.1",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.4",
        "webpack-merge": "^5.10.0"
    },
    "jest": {
        "collectCoverageFrom": [
            "<rootDir>/src/**/*{js,jsx,ts,tsx}"
        ],
        "coveragePathIgnorePatterns": [
            "<rootDir>/src/main.tsx"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/config/testSetup.ts"
        ],
        "moduleNameMapper": {
            "\\.(jpg|jpeg|png|gif|ico|woff|woff2|svg|ttf|eot)$": "<rootDir>/config/assetsTransformer.ts",
            "^.+\\.(css|scss)$": "<rootDir>/config/assetsTransformer.ts",
            "^@sealed-vote/contracts$": "<rootDir>/../../packages/contracts/src/index.ts",
            "^@sealed-vote/protocol$": "<rootDir>/../../packages/protocol/src/index.ts",
            "^@sealed-vote/testkit$": "<rootDir>/../../packages/testkit/src/index.ts"
        },
        "transform": {
            "^.+\\.[jt]sx?$": [
                "babel-jest",
                {
                    "configFile": "./.babelrc.cjs"
                }
            ]
        },
        "testEnvironment": "jsdom"
    }
}
