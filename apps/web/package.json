{
    "name": "@sealed-vote/web",
    "version": "2.2.0",
    "private": true,
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "AGPL-3.0-only",
    "description": "sealed.vote web application",
    "engines": {
        "node": ">=24.14.1"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "serve:dist": "node --experimental-strip-types config/serveDist.mts",
        "clean": "rimraf ./dist",
        "eslint": "pnpm --workspace-root exec eslint apps/web",
        "eslint:fix": "pnpm --workspace-root exec eslint apps/web --fix",
        "stylelint": "pnpm --workspace-root exec stylelint apps/web/src/index.css",
        "lint": "pnpm run eslint && pnpm run stylelint",
        "typecheck": "tsc",
        "test": "vitest run --reporter verbose",
        "test:update": "vitest run --update",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch"
    },
    "browserslist": [
        "> 0.5%",
        "not dead",
        "not IE > 0",
        "not op_mini all"
    ],
    "type": "module",
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "@resvg/resvg-js": "^2.6.2",
        "@sealed-vote/contracts": "workspace:*",
        "@sealed-vote/protocol": "workspace:*",
        "@tailwindcss/vite": "^4.2.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-error-boundary": "^6.1.1",
        "react-helmet-async": "^3.0.0",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.14.0",
        "redux": "^5.0.1",
        "sirv": "^3.0.2",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "threshold-elgamal": "catalog:",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "jsdom": "^29.0.2",
        "rimraf": "catalog:",
        "stylelint": "^17.6.0",
        "stylelint-config-standard": "^40.0.0",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
