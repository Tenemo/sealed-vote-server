{
    "name": "@sealed-vote/server",
    "version": "0.1.0",
    "description": "sealed-vote-server",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/sealed-vote-server.git"
    },
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "bugs": {
        "url": "https://github.com/Tenemo/sealed-vote-server/issues"
    },
    "homepage": "https://github.com/Tenemo/sealed-vote-server#readme",
    "scripts": {
        "start": "node dist/server.js",
        "build": "tsc --project tsconfig.build.json",
        "clean": "del-cli dist",
        "start:dev": "cross-env NODE_ENV=development tsx src/server.ts",
        "dev": "cross-env NODE_ENV=development nodemon",
        "db:reset": "tsx scripts/resetDb.ts",
        "lint": "eslint . --ext js,ts",
        "lint:fix": "eslint . --ext js,ts --fix",
        "typecheck": "tsc",
        "test": "cross-env NODE_ENV=test vitest run --reporter verbose",
        "test:watch": "vitest watch --clearScreen"
    },
    "type": "module",
    "dependencies": {
        "@fastify/postgres": "^6.0.2",
        "@nearform/sql": "^1.10.7",
        "@sealed-vote/contracts": "workspace:*",
        "@sealed-vote/protocol": "workspace:*",
        "@sinclair/typebox": "catalog:",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.0",
        "env-schema": "^7.0.0",
        "fastify": "^5.8.4",
        "fluent-json-schema": "^6.0.0",
        "http-errors": "^2.0.1",
        "pino-pretty": "^13.1.3",
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.39.0",
        "@sealed-vote/testkit": "workspace:*",
        "@types/eslint": "^9.6.1",
        "@types/eslint-plugin-prettier": "^3.1.3",
        "@types/http-errors": "^2.0.5",
        "@types/node": "^25.5.2",
        "@types/npm": "^7.19.3",
        "@types/pg": "^8.20.0",
        "@types/prettier": "^3.0.0",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "del-cli": "^7.0.0",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sql": "3.4.1",
        "nodemon": "^3.1.14",
        "pg": "^8.20.0",
        "ts-patch": "^3.3.0",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "catalog:",
        "typescript-transformer-esm": "^1.1.0",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
