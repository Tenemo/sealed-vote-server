{
    "name": "@sealed-vote/server",
    "version": "0.1.0",
    "description": "sealed-vote-server",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/sealed-vote-server.git"
    },
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "bugs": {
        "url": "https://github.com/Tenemo/sealed-vote-server/issues"
    },
    "homepage": "https://github.com/Tenemo/sealed-vote-server#readme",
    "scripts": {
        "start": "node dist/server.js",
        "build": "tsc --project tsconfig.build.json",
        "clean": "del-cli dist",
        "start:dev": "cross-env NODE_ENV=development tsx src/server.ts",
        "dev": "cross-env NODE_ENV=development nodemon",
        "db:reset": "tsx scripts/resetDb.ts",
        "lint": "eslint . --ext js,ts",
        "lint:fix": "eslint . --ext js,ts --fix",
        "typecheck": "tsc",
        "test": "cross-env NODE_ENV=test vitest run --reporter verbose",
        "test:watch": "vitest watch --clearScreen"
    },
    "type": "module",
    "dependencies": {
        "@fastify/postgres": "^5.2.2",
        "@nearform/sql": "^1.10.5",
        "@sealed-vote/contracts": "workspace:*",
        "@sealed-vote/protocol": "workspace:*",
        "@sinclair/typebox": "catalog:",
        "cross-env": "^7.0.3",
        "dotenv": "^16.4.5",
        "env-schema": "^5.2.1",
        "fastify": "^4.26.2",
        "fluent-json-schema": "^4.2.1",
        "http-errors": "^2.0.0",
        "pino-pretty": "^11.0.0",
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "@sealed-vote/testkit": "workspace:*",
        "@types/eslint": "^8.56.7",
        "@types/eslint-plugin-prettier": "^3.1.3",
        "@types/http-errors": "^2.0.4",
        "@types/node": "^20.12.6",
        "@types/npm": "^7.19.3",
        "@types/pg": "^8.11.5",
        "@types/prettier": "^2.7.3",
        "@typescript-eslint/eslint-plugin": "^7.6.0",
        "@typescript-eslint/parser": "^7.6.0",
        "del-cli": "^5.1.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-jest": "^27.9.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-security": "^2.1.1",
        "eslint-plugin-sql": "2.5.0",
        "nodemon": "^3.1.0",
        "pg": "^8.11.5",
        "ts-patch": "^3.1.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.7.2",
        "typescript": "catalog:",
        "typescript-transformer-esm": "^1.1.0",
        "vitest": "catalog:"
    }
}
