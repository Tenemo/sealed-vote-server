# Root environment values are passed through to workspace apps.
# Do not commit real credentials. Set deployment secrets on the platform.

NODE_ENV=development
PORT=4000
# Optional locally. Railway should set HOST=:: for dual-stack binding.
HOST=
LOG_LEVEL=debug
# Change this if localhost:5432 is already occupied by another local Postgres container.
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sv-db
# Set on Netlify after cutover. Leave empty for local dev, where Vite proxies /api.
VITE_API_BASE_URL=
