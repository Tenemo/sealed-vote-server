NODE_ENV=development
PORT=4000
# Optional locally. Railway should set HOST=:: for dual-stack binding.
HOST=
LOG_LEVEL=debug
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sv-db
# auto keeps local dev off and configured production databases on
DATABASE_SSL=auto
# Leave empty for local dev, where Vite proxies /api.
VITE_API_BASE_URL=
