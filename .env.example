# Optional locally. If empty, the backend uses the local docker database.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sv-db
# Optional for deployed API instances that serve a non-production frontend origin, such as Railway preview web.
WEB_APP_ORIGIN=
# Required for deployed web builds. Leave empty for local dev, where Vite proxies /api.
VITE_API_BASE_URL=
