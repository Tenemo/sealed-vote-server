{
    "name": "@sealed-vote/protocol",
    "private": true,
    "version": "2.3.0",
    "license": "AGPL-3.0-only",
    "engines": {
        "node": ">=24.14.1"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "clean": "rimraf dist",
        "lint": "pnpm --workspace-root exec eslint packages/protocol",
        "lint:fix": "pnpm --workspace-root exec eslint packages/protocol --fix",
        "test": "vitest run --reporter verbose"
    },
    "dependencies": {
        "@sealed-vote/contracts": "workspace:*",
        "bigint-mod-arith": "^3.3.1",
        "decimal.js": "^10.6.0",
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "catalog:",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
