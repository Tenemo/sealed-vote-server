{
    "name": "@sealed-vote/protocol",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "clean": "rimraf dist",
        "lint": "pnpm exec eslint .",
        "lint:fix": "pnpm exec eslint . --fix",
        "test": "vitest run --reporter verbose"
    },
    "dependencies": {
        "@sealed-vote/contracts": "workspace:*",
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "eslint": "^9.39.4",
        "rimraf": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vitest": "catalog:"
    }
}
