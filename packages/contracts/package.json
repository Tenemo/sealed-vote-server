{
    "name": "@sealed-vote/contracts",
    "private": true,
    "version": "2.3.0",
    "license": "AGPL-3.0-only",
    "engines": {
        "node": ">=24.14.1"
    },
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "rimraf dist && tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "clean": "rimraf dist",
        "lint": "pnpm --workspace-root exec eslint packages/contracts",
        "lint:fix": "pnpm --workspace-root exec eslint packages/contracts --fix",
        "test": "node --experimental-strip-types --test tests/*.spec.ts"
    },
    "dependencies": {
        "threshold-elgamal": "catalog:"
    },
    "devDependencies": {
        "rimraf": "catalog:",
        "typescript": "catalog:"
    }
}
