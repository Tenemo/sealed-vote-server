{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "ignoreDeprecations": "6.0",
        "strict": true,
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,
        "outDir": "dist",
        "rootDir": "src",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*"]
}
