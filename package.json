{
    "name": "sealed-vote",
    "version": "2.1.0",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "license": "AGPL-3.0-only",
    "engines": {
        "node": ">=24.14.1"
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test --output-logs=errors-only --log-prefix=none",
        "lint": "turbo run lint --output-logs=errors-only --log-prefix=none",
        "typecheck": "turbo run typecheck --output-logs=errors-only --log-prefix=none",
        "e2e": "node --experimental-strip-types tests/e2e/scripts/run-e2e.mts",
        "e2e:ci:build": "turbo run build --force --filter=@sealed-vote/contracts --filter=@sealed-vote/protocol --filter=@sealed-vote/api --filter=@sealed-vote/web",
        "e2e:ci:serve:api": "node --experimental-strip-types tests/e2e/scripts/run-e2e-ci-api.mts",
        "e2e:ci:test": "node --experimental-strip-types tests/e2e/scripts/run-e2e-ci.mts",
        "e2e:ci:serve:web": "node --experimental-strip-types tests/e2e/scripts/run-e2e-ci-web.mts",
        "e2e:guard": "node --experimental-strip-types tests/e2e/scripts/assert-safe-e2e-env.mts",
        "e2e:install": "playwright install --with-deps chromium firefox webkit",
        "e2e:production:test": "node --experimental-strip-types tests/e2e/scripts/run-production-e2e.mts",
        "e2e:production:wait": "node --experimental-strip-types tests/e2e/scripts/wait-for-production-deploy.mts",
        "clean": "turbo run clean",
        "docker:up": "docker compose up -d",
        "docker:destroy": "docker compose down -v --remove-orphans",
        "docker:wipe": "pnpm docker:destroy && pnpm docker:up",
        "docker:reset": "pnpm docker:wipe",
        "local:reset": "pnpm docker:reset && pnpm db:setup",
        "db:generate": "pnpm --filter @sealed-vote/api db:generate",
        "db:migrate": "pnpm --filter @sealed-vote/api db:migrate",
        "db:reset": "pnpm --filter @sealed-vote/api db:reset",
        "db:seed": "pnpm --filter @sealed-vote/api db:seed",
        "db:setup": "pnpm --filter @sealed-vote/api db:setup",
        "prepare": "husky"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.4",
        "@eslint/js": "^9.39.0",
        "@playwright/test": "^1.59.1",
        "eslint": "^9.39.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sql": "3.4.1",
        "globals": "^17.4.0",
        "husky": "catalog:",
        "prettier": "^3.8.1",
        "typescript": "catalog:",
        "typescript-eslint": "^8.58.0",
        "turbo": "^2.9.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "esbuild",
            "multiline-ts",
            "unrs-resolver"
        ]
    }
}
