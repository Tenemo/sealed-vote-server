{
    "name": "sealed-vote",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=20.11.0"
    },
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "e2e": "pnpm build && playwright test",
        "e2e:install": "playwright install --with-deps",
        "clean": "turbo run clean",
        "docker:up": "docker compose up -d",
        "docker:destroy": "docker compose down -v --remove-orphans",
        "docker:wipe": "pnpm docker:destroy && pnpm docker:up",
        "docker:reset": "pnpm docker:wipe",
        "db:reset": "pnpm --filter @sealed-vote/server db:reset",
        "prepare": "husky",
        "postinstall": "pnpm --filter @sealed-vote/server exec ts-patch install -s"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "husky": "catalog:",
        "turbo": "^2.9.3"
    }
}
