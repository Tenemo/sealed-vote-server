{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "env": [
                "COMMIT_REF",
                "GITHUB_SHA",
                "RAILWAY_GIT_COMMIT_SHA",
                "VITE_API_BASE_URL",
                "VITE_POLLING_INTERVAL_MS"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".git/HEAD",
                ".git/packed-refs",
                ".git/refs/**"
            ],
            "outputs": ["dist/**"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "lint": {
            "dependsOn": ["^build"]
        },
        "typecheck": {
            "dependsOn": ["^build"]
        },
        "clean": {
            "cache": false
        }
    }
}
